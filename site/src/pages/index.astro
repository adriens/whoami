---
import '@fortawesome/fontawesome-free/css/all.min.css';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const root = resolve(__dirname, '../../..');

const resume = JSON.parse(readFileSync(resolve(root, 'manual/resume.json'), 'utf-8'));
const { basics, work = [], education = [], skills = [], projects = [], languages = [], publications = [], awards = [] } = resume;

// ── CSV parser ──────────────────────────────────────────────────────────────
function splitRow(row: string): string[] {
  const result: string[] = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < row.length; i++) {
    const ch = row[i];
    if (ch === '"') {
      if (inQuotes && row[i + 1] === '"') { current += '"'; i++; }
      else { inQuotes = !inQuotes; }
    } else if (ch === ',' && !inQuotes) {
      result.push(current); current = '';
    } else {
      current += ch;
    }
  }
  result.push(current);
  return result;
}

function parseCSV(path: string): Record<string, string>[] {
  if (!existsSync(path)) return [];
  const lines = readFileSync(path, 'utf-8').trim().split('\n').map(l => l.replace(/\r$/, ''));
  if (lines.length < 2) return [];
  const headers = splitRow(lines[0]);
  return lines.slice(1).filter(l => l.trim()).map(line => {
    const values = splitRow(line);
    return Object.fromEntries(headers.map((h, i) => [h, values[i] ?? '']));
  });
}

// ── Load data ───────────────────────────────────────────────────────────────
function readJSON(path: string): any {
  try { return JSON.parse(readFileSync(path, 'utf-8')); } catch { return {}; }
}

const articlesAdriens = parseCSV(resolve(root, 'data/dev_to/adriens/_index.csv'));
const articlesOptNc   = parseCSV(resolve(root, 'data/dev_to/opt-nc/_index.csv'));
const videos          = parseCSV(resolve(root, 'data/youtube/devops-lab/_index.csv'));
const books           = parseCSV(resolve(root, 'data/goodreads/124105866/_index.csv'));
const kaggleDatasets  = parseCSV(resolve(root, 'data/kaggle/adriensales/_index.csv'));
const hfDatasets      = parseCSV(resolve(root, 'data/huggingface/rastadidi/_datasets_index.csv'));
const hfSpaces        = parseCSV(resolve(root, 'data/huggingface/rastadidi/_spaces_index.csv'));
const ytStats         = readJSON(resolve(root, 'data/youtube/devops-lab/_stats.json'));

const totalArticles   = articlesAdriens.length + articlesOptNc.length;
const totalVideos     = videos.length;
const totalBooks      = books.length;
const totalDatasets   = kaggleDatasets.length;
const totalDownloads  = kaggleDatasets.reduce((sum, d) => sum + (parseInt(d.download_count) || 0), 0);
const totalHFDatasets = hfDatasets.length;
const totalHFSpaces   = hfSpaces.length;
const totalReactions  = [...articlesAdriens, ...articlesOptNc].reduce((sum, a) => sum + (parseInt(a.reactions) || 0), 0);
const ytSubscribers   = ytStats.subscriber_count || 0;

const firstYear = work.length > 0
  ? parseInt(work[work.length - 1].startDate?.substring(0, 4) ?? '2000')
  : 2000;
const yearsXP = new Date().getFullYear() - firstYear;

const latestArticles = [...articlesAdriens]
  .sort((a, b) => b.published_at.localeCompare(a.published_at))
  .slice(0, 6);

const latestVideos = [...videos]
  .sort((a, b) => b.published_at.localeCompare(a.published_at))
  .slice(0, 5);

const topDatasets = [...kaggleDatasets]
  .sort((a, b) => (parseInt(b.download_count) || 0) - (parseInt(a.download_count) || 0))
  .filter(d => (parseInt(d.download_count) || 0) > 0)
  .slice(0, 6);

function formatDate(iso: string): string {
  const d = iso.substring(0, 10);
  if (!d || d === '0000-00-00') return '';
  const [y, m] = d.split('-');
  const months = ['jan','fév','mar','avr','mai','jun','jul','aoû','sep','oct','nov','déc'];
  return `${months[parseInt(m) - 1]} ${y}`;
}

// ── Network icons ────────────────────────────────────────────────────────────
const networkIcons: Record<string, string> = {
  github:        'fa-brands fa-github',
  linkedin:      'fa-brands fa-linkedin',
  twitter:       'fa-brands fa-twitter',
  'x (twitter)': 'fa-brands fa-x-twitter',
  x:             'fa-brands fa-x-twitter',
  youtube:       'fa-brands fa-youtube',
  'dev.to':      'fa-brands fa-dev',
  devto:         'fa-brands fa-dev',
  stackoverflow: 'fa-brands fa-stack-overflow',
  mastodon:      'fa-brands fa-mastodon',
  instagram:     'fa-brands fa-instagram',
  bluesky:       'fa-brands fa-bluesky',
  twitch:        'fa-brands fa-twitch',
  kaggle:        'fa-brands fa-kaggle',
  pypi:          'fa-brands fa-python',
  goodreads:     'fa-brands fa-goodreads',
  huggingface:   'hf-icon',
  chocolatey:    'choco-icon',
};

function networkIcon(network: string): string {
  return networkIcons[network.toLowerCase()] ?? 'fa-solid fa-link';
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{basics.name} — {basics.label}</title>
    <meta name="description" content={basics.summary} />
  </head>
  <body>
    <main>
      <header>
        <div class="name-block">
          <h1>{basics.name}</h1>
          {basics.label && (
            <div class="label-tags">
              {basics.label.split('|').map((t: string) => (
                <span class="label-tag">{t.trim()}</span>
              ))}
            </div>
          )}
        </div>
        <div class="contact">
          {basics.email && (
            <a href={`mailto:${basics.email}`} title={basics.email}>
              <i class="fa-solid fa-envelope"></i>
            </a>
          )}
          {basics.location && (
            <span title={`${basics.location.city}, ${basics.location.countryCode}`}>
              <i class="fa-solid fa-location-dot"></i>
              <span class="contact-label">{basics.location.city}</span>
            </span>
          )}
          {basics.url && (
            <a href={basics.url} target="_blank" rel="noopener" title={basics.url}>
              <i class="fa-solid fa-globe"></i>
            </a>
          )}
          {basics.profiles?.map((p: any) => {
            const icon = networkIcon(p.network);
            return (
              <a href={p.url} target="_blank" rel="noopener" title={p.network}>
                {icon === 'hf-icon'
                  ? <span class="hf-emoji" aria-label="HuggingFace">🤗</span>
                  : icon === 'choco-icon'
                  ? <span class="hf-emoji" aria-label="Chocolatey">🍫</span>
                  : <i class={icon}></i>
                }
              </a>
            );
          })}
        </div>
      </header>

      <!-- ── Stats bar ─────────────────────────────────────── -->
      <div class="stats-bar">
        <div class="stat">
          <span class="stat-value">{totalArticles}</span>
          <span class="stat-label"><i class="fa-brands fa-dev"></i> articles</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalVideos}</span>
          <span class="stat-label"><i class="fa-brands fa-youtube"></i> vidéos</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalBooks}</span>
          <span class="stat-label"><i class="fa-solid fa-book"></i> livres lus</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalDatasets}</span>
          <span class="stat-label"><i class="fa-brands fa-kaggle"></i> datasets</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalDownloads.toLocaleString('fr')}</span>
          <span class="stat-label"><i class="fa-solid fa-download"></i> downloads</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalHFDatasets}</span>
          <span class="stat-label"><span class="hf-emoji-sm">🤗</span> HF datasets</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalHFSpaces}</span>
          <span class="stat-label"><span class="hf-emoji-sm">🤗</span> HF apps</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalReactions.toLocaleString('fr')}</span>
          <span class="stat-label"><i class="fa-brands fa-dev"></i> réactions</span>
        </div>
        <div class="stat">
          <span class="stat-value">{ytSubscribers}</span>
          <span class="stat-label"><i class="fa-brands fa-youtube"></i> abonnés</span>
        </div>
        <div class="stat">
          <span class="stat-value">{yearsXP}+</span>
          <span class="stat-label"><i class="fa-solid fa-calendar"></i> ans d'XP</span>
        </div>
      </div>

      {basics.summary && (() => {
        const paragraphs = basics.summary.split('\n\n').filter((p: string) => p.trim());
        return (
          <section class="summary">
            <p class="summary-abstract">{paragraphs[0]}</p>
            {paragraphs.slice(1).map((p: string) => (
              <p class="summary-detail">{p}</p>
            ))}
          </section>
        );
      })()}

      {work.length > 0 && (
        <section>
          <h2>Expérience</h2>
          {work.map((w: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{w.position}</strong>
                  <span class="company">@ {w.name}</span>
                  {w.url && (
                    <a href={w.url} target="_blank" rel="noopener" class="ext" title={w.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                <time>{w.startDate} → {w.endDate ?? 'présent'}</time>
              </div>
              {w.summary && <p class="muted">{w.summary}</p>}
              {w.highlights?.length > 0 && (
                <ul>
                  {w.highlights.map((h: string) => <li>{h}</li>)}
                </ul>
              )}
            </article>
          ))}
        </section>
      )}

      {skills.length > 0 && (
        <section>
          <h2>Compétences</h2>
          <div class="skills-grid">
            {skills.map((s: any) => (
              <div class="skill-card">
                <div class="skill-meta">
                  <strong>{s.name}</strong>
                  <span class="level">{s.level}</span>
                </div>
                {s.keywords?.length > 0 && (
                  <div class="tags">
                    {s.keywords.map((k: string) => <span class="tag">{k}</span>)}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {education.length > 0 && (
        <section>
          <h2>Formation</h2>
          {education.map((e: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{e.studyType} {e.area}</strong>
                  <span class="company">@ {e.institution}</span>
                </div>
                <time>{e.startDate} → {e.endDate ?? 'présent'}</time>
              </div>
            </article>
          ))}
        </section>
      )}

      {projects.length > 0 && (
        <section>
          <h2>Projets open source</h2>
          {projects.map((p: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{p.name}</strong>
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noopener" class="ext" title={p.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                {p.startDate && (
                  <time>{p.startDate}{p.endDate ? ` → ${p.endDate}` : ''}</time>
                )}
              </div>
              {p.description && <p class="muted">{p.description}</p>}
              {p.highlights?.length > 0 && (
                <ul>
                  {p.highlights.map((h: string) => <li>{h}</li>)}
                </ul>
              )}
            </article>
          ))}
        </section>
      )}

      {publications.length > 0 && (
        <section>
          <h2>Publications</h2>
          {publications.map((p: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{p.name}</strong>
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noopener" class="ext" title={p.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                {p.releaseDate && <time>{p.releaseDate}</time>}
              </div>
              {p.summary && <p class="muted">{p.summary}</p>}
            </article>
          ))}
        </section>
      )}

      {awards.length > 0 && (
        <section>
          <h2>Distinctions</h2>
          {awards.map((a: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{a.title}</strong>
                  {a.awarder && <span class="company">@ {a.awarder}</span>}
                </div>
                {a.date && <time>{a.date}</time>}
              </div>
              {a.summary && <p class="muted">{a.summary}</p>}
            </article>
          ))}
        </section>
      )}

      <!-- ── Derniers articles DEV.to ───────────────────────── -->
      {latestArticles.length > 0 && (
        <section>
          <h2>
            <i class="fa-brands fa-dev"></i> Derniers articles DEV.to
          </h2>
          <ul class="article-list">
            {latestArticles.map((a) => (
              <li class="article-item">
                <a href={a.url} target="_blank" rel="noopener" class="article-title">
                  {a.title}
                </a>
                <div class="article-meta">
                  <span class="article-date">{formatDate(a.published_at)}</span>
                  {a.reactions && parseInt(a.reactions) > 0 && (
                    <span class="article-stat">
                      <i class="fa-solid fa-heart"></i> {a.reactions}
                    </span>
                  )}
                  {a.reading_time_minutes && (
                    <span class="article-stat">
                      <i class="fa-regular fa-clock"></i> {a.reading_time_minutes} min
                    </span>
                  )}
                  {a.is_dev_challenge === 'True' && (
                    <span class="challenge-badge">DEV Challenge</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
          <a href="https://dev.to/adriens" target="_blank" rel="noopener" class="see-all">
            Voir tous les articles <i class="fa-solid fa-arrow-up-right-from-square"></i>
          </a>
        </section>
      )}

      <!-- ── Dernières vidéos YouTube ───────────────────────── -->
      {latestVideos.length > 0 && (
        <section>
          <h2>
            <i class="fa-brands fa-youtube"></i> Dernières vidéos YouTube
          </h2>
          <ul class="article-list">
            {latestVideos.map((v) => (
              <li class="article-item">
                <a href={v.url} target="_blank" rel="noopener" class="article-title">
                  {v.title}
                </a>
                <div class="article-meta">
                  <span class="article-date">{formatDate(v.published_at)}</span>
                  {v.views && parseInt(v.views) > 0 && (
                    <span class="article-stat">
                      <i class="fa-solid fa-eye"></i> {parseInt(v.views).toLocaleString('fr')}
                    </span>
                  )}
                  {v.duration_seconds && (
                    <span class="article-stat">
                      <i class="fa-regular fa-clock"></i> {Math.round(parseInt(v.duration_seconds) / 60)} min
                    </span>
                  )}
                </div>
              </li>
            ))}
          </ul>
          <a href="https://www.youtube.com/@devopslabs2812" target="_blank" rel="noopener" class="see-all">
            Voir toutes les vidéos <i class="fa-solid fa-arrow-up-right-from-square"></i>
          </a>
        </section>
      )}

      <!-- ── Top datasets Kaggle ───────────────────────────── -->
      {topDatasets.length > 0 && (
        <section>
          <h2>
            <i class="fa-brands fa-kaggle"></i> Top datasets Kaggle
          </h2>
          <ul class="article-list">
            {topDatasets.map((d) => (
              <li class="article-item">
                <a href={d.url} target="_blank" rel="noopener" class="article-title">
                  {d.title}
                </a>
                <div class="article-meta">
                  <span class="article-stat">
                    <i class="fa-solid fa-download"></i> {parseInt(d.download_count).toLocaleString('fr')}
                  </span>
                  {d.view_count && parseInt(d.view_count) > 0 && (
                    <span class="article-stat">
                      <i class="fa-solid fa-eye"></i> {parseInt(d.view_count).toLocaleString('fr')}
                    </span>
                  )}
                  {d.last_updated && (
                    <span class="article-date">{formatDate(d.last_updated)}</span>
                  )}
                </div>
              </li>
            ))}
          </ul>
          <a href="https://www.kaggle.com/adriensales/datasets" target="_blank" rel="noopener" class="see-all">
            Voir tous les datasets <i class="fa-solid fa-arrow-up-right-from-square"></i>
          </a>
        </section>
      )}

      {languages.length > 0 && (
        <section>
          <h2>Langues</h2>
          <div class="lang-list">
            {languages.map((l: any) => (
              <span><strong>{l.language}</strong> — {l.fluency}</span>
            ))}
          </div>
        </section>
      )}
    </main>

    <footer>
      <a href="https://github.com/adriens/whoami" target="_blank" rel="noopener" title="Source — adriens/whoami">
        <i class="fa-brands fa-github"></i>
      </a>
      <a href="https://raw.githubusercontent.com/adriens/whoami/main/manual/resume.json" target="_blank" rel="noopener" title="resume.json">
        <i class="fa-solid fa-file-code"></i>
      </a>
    </footer>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --accent:  #60a5fa;
    --text:    #f1f5f9;
    --muted:   #94a3b8;
    --border:  #334155;
    --bg:      #0f172a;
    --surface: #1e293b;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
    font-size: 15px;
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  /* ── Header ── */
  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--accent);
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .label-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .label-tag {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
  }

  .contact {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    padding-top: 0.35rem;
  }

  .contact a,
  .contact span {
    color: var(--muted);
    text-decoration: none;
    font-size: 1.15rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: opacity 0.15s;
  }

  .contact a:hover { opacity: 0.75; }

  .contact .fa-github        { color: #e6edf3; }
  .contact .fa-linkedin      { color: #0a66c2; }
  .contact .fa-dev           { color: #ffffff; }
  .contact .fa-youtube       { color: #ff0000; }
  .contact .fa-kaggle        { color: #20beff; }
  .contact .fa-x-twitter     { color: #e7e9ea; }
  .contact .fa-python        { color: #3775a9; }
  .contact .fa-goodreads     { color: #f4f1ea; }
  .hf-emoji { font-size: 1rem; line-height: 1; }
  .hf-emoji-sm { font-size: 0.85rem; line-height: 1; }
  .contact-label { font-size: 0.8rem; }

  /* ── Stats bar ── */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    margin-top: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--surface);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.1rem 0.5rem;
    border-right: 1px solid var(--border);
    gap: 0.25rem;
  }

  .stat:last-child { border-right: none; }

  .stat-value {
    font-size: 1.85rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  /* ── Sections ── */
  section { margin-top: 2rem; }

  h2 {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .summary-abstract {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.75;
    font-weight: 500;
  }

  .summary-detail {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.75;
    margin-top: 0.75rem;
  }

  /* ── Entries ── */
  .entry { margin-bottom: 1.5rem; }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .entry-title { display: flex; align-items: baseline; gap: 0.35rem; flex-wrap: wrap; }
  .entry-title strong { font-size: 0.95rem; color: var(--text); }
  .company { color: var(--muted); font-size: 0.88rem; }

  .ext {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.7rem;
    opacity: 0.6;
    transition: opacity 0.15s, color 0.15s;
  }
  .ext:hover { opacity: 1; color: var(--accent); }

  time {
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .muted {
    font-size: 0.88rem;
