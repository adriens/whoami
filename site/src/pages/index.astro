---
import '@fortawesome/fontawesome-free/css/all.min.css';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const root = resolve(__dirname, '../../..');

const resume = JSON.parse(readFileSync(resolve(root, 'manual/resume.json'), 'utf-8'));
const { basics, work = [], education = [], skills = [], projects = [], languages = [], publications = [], awards = [], volunteer = [], interests = [], certificates = [] } = resume;

const githubProfile   = basics.profiles?.find((p: any) => p.network.toLowerCase() === 'github');
const linkedinProfile = basics.profiles?.find((p: any) => p.network.toLowerCase() === 'linkedin');

const openSourceProjects   = projects.filter((p: any) => p.type === 'open-source');
const professionalProjects = projects.filter((p: any) => p.type === 'professional');
const sortedAwards = [...awards].sort((a: any, b: any) => (b.date ?? '').localeCompare(a.date ?? ''));

function awardBadgeClass(date: string): string {
  const year = parseInt(date?.substring(0, 4) ?? '2000');
  if (year >= 2025) return 'award-badge award-badge-accent';
  if (year >= 2023) return 'award-badge award-badge-blue';
  if (year >= 2020) return 'award-badge award-badge-muted';
  return 'award-badge award-badge-dim';
}

// ── CSV parser ──────────────────────────────────────────────────────────────
function splitRow(row: string): string[] {
  const result: string[] = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < row.length; i++) {
    const ch = row[i];
    if (ch === '"') {
      if (inQuotes && row[i + 1] === '"') { current += '"'; i++; }
      else { inQuotes = !inQuotes; }
    } else if (ch === ',' && !inQuotes) {
      result.push(current); current = '';
    } else {
      current += ch;
    }
  }
  result.push(current);
  return result;
}

function parseCSV(path: string): Record<string, string>[] {
  if (!existsSync(path)) return [];
  const lines = readFileSync(path, 'utf-8').trim().split('\n').map(l => l.replace(/\r$/, ''));
  if (lines.length < 2) return [];
  const headers = splitRow(lines[0]);
  return lines.slice(1).filter(l => l.trim()).map(line => {
    const values = splitRow(line);
    return Object.fromEntries(headers.map((h, i) => [h, values[i] ?? '']));
  });
}

// ── Load data ───────────────────────────────────────────────────────────────
function readJSON(path: string): any {
  try { return JSON.parse(readFileSync(path, 'utf-8')); } catch { return {}; }
}

const articlesAdriens = parseCSV(resolve(root, 'data/dev_to/adriens/_index.csv'));
const articlesOptNc   = parseCSV(resolve(root, 'data/dev_to/opt-nc/_index.csv'));
const videos          = parseCSV(resolve(root, 'data/youtube/devops-lab/_index.csv'));
const books           = parseCSV(resolve(root, 'data/goodreads/124105866/_index.csv'));
const kaggleDatasets  = parseCSV(resolve(root, 'data/kaggle/adriensales/_index.csv'));
const hfDatasets      = parseCSV(resolve(root, 'data/huggingface/rastadidi/_datasets_index.csv'));
const hfSpaces        = parseCSV(resolve(root, 'data/huggingface/rastadidi/_spaces_index.csv'));
const ytStats         = readJSON(resolve(root, 'data/youtube/devops-lab/_stats.json'));

const totalArticles   = articlesAdriens.length + articlesOptNc.length;
const totalVideos     = videos.length;
const totalBooks      = books.length;
const totalDatasets   = kaggleDatasets.length;
const totalDownloads  = kaggleDatasets.reduce((sum, d) => sum + (parseInt(d.download_count) || 0), 0);
const totalHFDatasets = hfDatasets.length;
const totalHFSpaces   = hfSpaces.length;
const totalReactions  = [...articlesAdriens, ...articlesOptNc].reduce((sum, a) => sum + (parseInt(a.reactions) || 0), 0);
const ytSubscribers   = ytStats.subscriber_count || 0;

const firstYear = work.length > 0
  ? parseInt(work[work.length - 1].startDate?.substring(0, 4) ?? '2000')
  : 2000;
const yearsXP = new Date().getFullYear() - firstYear;

const latestArticles = [...articlesAdriens]
  .sort((a, b) => b.published_at.localeCompare(a.published_at))
  .slice(0, 6);

const latestVideos = [...videos]
  .sort((a, b) => b.published_at.localeCompare(a.published_at))
  .slice(0, 5);

const topDatasets = [...kaggleDatasets]
  .sort((a, b) => (parseInt(b.download_count) || 0) - (parseInt(a.download_count) || 0))
  .filter(d => (parseInt(d.download_count) || 0) > 0)
  .slice(0, 6);

function formatDate(iso: string): string {
  const d = iso.substring(0, 10);
  if (!d || d === '0000-00-00') return '';
  const [y, m] = d.split('-');
  const months = ['jan','fév','mar','avr','mai','jun','jul','aoû','sep','oct','nov','déc'];
  return `${months[parseInt(m) - 1]} ${y}`;
}

// ── Network icons ────────────────────────────────────────────────────────────
const networkIcons: Record<string, string> = {
  github:        'fa-brands fa-github',
  linkedin:      'fa-brands fa-linkedin',
  twitter:       'fa-brands fa-twitter',
  'x (twitter)': 'fa-brands fa-x-twitter',
  x:             'fa-brands fa-x-twitter',
  youtube:       'fa-brands fa-youtube',
  'dev.to':      'fa-brands fa-dev',
  devto:         'fa-brands fa-dev',
  stackoverflow: 'fa-brands fa-stack-overflow',
  mastodon:      'fa-brands fa-mastodon',
  instagram:     'fa-brands fa-instagram',
  bluesky:       'fa-brands fa-bluesky',
  twitch:        'fa-brands fa-twitch',
  kaggle:        'fa-brands fa-kaggle',
  pypi:          'fa-brands fa-python',
  goodreads:     'fa-brands fa-goodreads',
  huggingface:   'hf-icon',
  chocolatey:    'choco-icon',
};

function networkIcon(network: string): string {
  return networkIcons[network.toLowerCase()] ?? 'fa-solid fa-link';
}

const _18monthsAgo = new Date();
_18monthsAgo.setMonth(_18monthsAgo.getMonth() - 18);
function isRecent(dateStr: string | undefined): boolean {
  if (!dateStr) return false;
  const d = new Date(dateStr.length === 7 ? dateStr + '-01' : dateStr);
  return d >= _18monthsAgo;
}

function langFlag(lang: string): string {
  const map: Record<string, string> = {
    'français': '🇫🇷', 'anglais': '🇬🇧', 'allemand': '🇩🇪', 'espagnol': '🇪🇸',
  };
  return map[lang.toLowerCase()] ?? '🌐';
}

function interestIcon(name: string): string {
  const n = name.toLowerCase();
  if (n.includes('sport') || n.includes('nautique') || n.includes('outdoor')) return 'fa-solid fa-person-running';
  if (n.includes('maker') || n.includes('iot')) return 'fa-solid fa-microchip';
  if (n.includes('veille') || n.includes('technologique')) return 'fa-solid fa-binoculars';
  if (n.includes('création') || n.includes('humour')) return 'fa-solid fa-film';
  if (n.includes('écriture') || n.includes('livre')) return 'fa-solid fa-pen-nib';
  if (n.includes('musique')) return 'fa-solid fa-music';
  if (n.includes('lecture')) return 'fa-solid fa-book-open';
  return 'fa-solid fa-star';
}

function levelDots(level: string): number {
  const map: Record<string, number> = {
    'expert': 5, 'avancé': 4, 'intermédiaire': 3, 'débutant': 2, 'notions': 1
  };
  return map[level?.toLowerCase()] ?? 3;
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{basics.name} — {basics.label}</title>
    <meta name="description" content={basics.summary?.split('\n\n')[0]?.substring(0, 300)} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={`${basics.name} — CV & profil`} />
    <meta property="og:description" content={basics.summary?.split('\n\n')[0]?.substring(0, 300)} />
    <meta property="og:url" content="https://adriens.github.io/whoami/" />
    <meta property="og:site_name" content={basics.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@rastadidi" />
    <link rel="icon" type="image/svg+xml" href="/whoami/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="progress-bar"></div>
    <div id="toast" role="status" aria-live="polite"></div>
    <nav class="side-nav" aria-label="Navigation sections">
      <a href="#experience"   class="snav-link" title="Expérience"><i class="fa-solid fa-briefcase"></i></a>
      <a href="#benevolat"    class="snav-link" title="Bénévolat"><i class="fa-solid fa-heart"></i></a>
      <a href="#competences"  class="snav-link" title="Compétences"><i class="fa-solid fa-screwdriver-wrench"></i></a>
      <a href="#formation"    class="snav-link" title="Formation"><i class="fa-solid fa-graduation-cap"></i></a>
      <a href="#open-source"  class="snav-link" title="Projets open source"><i class="fa-brands fa-github"></i></a>
      <a href="#professionnel" class="snav-link" title="Réalisations pro"><i class="fa-solid fa-building"></i></a>
      <a href="#distinctions" class="snav-link" title="Distinctions"><i class="fa-solid fa-trophy"></i></a>
      <a href="#articles"     class="snav-link" title="Articles DEV.to"><i class="fa-brands fa-dev"></i></a>
      <a href="#interets"     class="snav-link" title="Intérêts"><i class="fa-solid fa-heart-pulse"></i></a>
    </nav>
    <button id="pdf-btn" aria-label="Exporter en PDF" title="Exporter en PDF">
      <i class="fa-solid fa-file-pdf"></i>
    </button>
    <button id="theme-toggle" aria-label="Basculer le thème" title="Basculer thème clair/sombre">
      <i class="fa-solid fa-sun" id="icon-sun"></i>
      <i class="fa-solid fa-moon" id="icon-moon"></i>
    </button>
    <main>
      <header>
        <div class="name-block">
          <h1>{basics.name}</h1>
          {basics.label && (
            <div class="label-tags">
              {basics.label.split('|').map((t: string) => (
                <span class="label-tag">{t.trim()}</span>
              ))}
            </div>
          )}
        </div>
        <div class="contact">
          {basics.email && (
            <a href={`mailto:${basics.email}`} title={basics.email} data-copy-email={basics.email}>
              <i class="fa-solid fa-envelope"></i>
            </a>
          )}
          {basics.location && (
            <span title={`${basics.location.city}, ${basics.location.countryCode}`}>
              <i class="fa-solid fa-location-dot"></i>
              <span class="contact-label">{basics.location.city}</span>
            </span>
          )}
          {basics.url && (
            <a href={basics.url} target="_blank" rel="noopener" title={basics.url}>
              <i class="fa-solid fa-globe"></i>
            </a>
          )}
          {basics.profiles?.map((p: any) => {
            const icon = networkIcon(p.network);
            return (
              <a href={p.url} target="_blank" rel="noopener" title={p.network}>
                {icon === 'hf-icon'
                  ? <span class="hf-emoji" aria-label="HuggingFace">🤗</span>
                  : icon === 'choco-icon'
                  ? <span class="hf-emoji" aria-label="Chocolatey">🍫</span>
                  : <i class={icon}></i>
                }
              </a>
            );
          })}
        </div>
      </header>

      <!-- ── Stats bar ─────────────────────────────────────── -->
      <div class="stats-card">
      <div class="stats-bar">
        <div class="stat">
          <span class="stat-value">{totalArticles}</span>
          <span class="stat-label"><i class="fa-brands fa-dev"></i> articles</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalVideos}</span>
          <span class="stat-label"><i class="fa-brands fa-youtube"></i> vidéos</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalBooks}</span>
          <span class="stat-label"><i class="fa-solid fa-book"></i> livres lus</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalDatasets}</span>
          <span class="stat-label"><i class="fa-brands fa-kaggle"></i> datasets</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalDownloads.toLocaleString('fr')}</span>
          <span class="stat-label"><i class="fa-solid fa-download"></i> downloads</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalHFDatasets}</span>
          <span class="stat-label"><span class="hf-emoji-sm">🤗</span> datasets</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalHFSpaces}</span>
          <span class="stat-label"><span class="hf-emoji-sm">🤗</span> apps</span>
        </div>
        <div class="stat">
          <span class="stat-value">{totalReactions.toLocaleString('fr')}</span>
          <span class="stat-label"><i class="fa-brands fa-dev"></i> réactions</span>
        </div>
        <div class="stat">
          <span class="stat-value">{ytSubscribers}</span>
          <span class="stat-label"><i class="fa-brands fa-youtube"></i> abonnés</span>
        </div>
        <div class="stat">
          <span class="stat-value">{yearsXP}+</span>
          <span class="stat-label"><i class="fa-solid fa-calendar"></i> ans d'XP</span>
        </div>
      </div>
      </div>

      {basics.summary && (() => {
        const paragraphs = basics.summary.split('\n\n').filter((p: string) => p.trim());
        return (
          <section class="summary">
            <p class="summary-abstract">{paragraphs[0]}</p>
            {paragraphs.slice(1).map((p: string) => (
              <p class="summary-detail">{p}</p>
            ))}
          </section>
        );
      })()}

      {work.length > 0 && (
        <section id="experience">
          <h2><i class="fa-solid fa-briefcase"></i> Expérience</h2>
          <div class="timeline">
            {work.map((w: any) => (
              <div class="tl-item">
                <div class="tl-dot"></div>
                <article class="entry">
                  <div class="entry-header">
                    <div class="entry-title">
                      <strong>{w.position}</strong>
                      <span class="company">@ {w.name}</span>
                      {w.url && (
                        <a href={w.url} target="_blank" rel="noopener" class="ext" title={w.name}>
                          <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </a>
                      )}
                    </div>
                    <time>{w.startDate} → {w.endDate ?? 'présent'}</time>
                  </div>
                  {w.summary && <p class="muted">{w.summary}</p>}
                  {w.highlights?.length > 0 && (
                    <details class="highlights-toggle" open>
                      <summary><i class="fa-solid fa-chevron-down"></i> {w.highlights.length} point{w.highlights.length > 1 ? 's' : ''} clé{w.highlights.length > 1 ? 's' : ''}</summary>
                      <ul>
                        {w.highlights.map((h: string) => <li>{h}</li>)}
                      </ul>
                    </details>
                  )}
                </article>
              </div>
            ))}
          </div>
        </section>
      )}

      {volunteer.length > 0 && (
        <section id="benevolat">
          <h2><i class="fa-solid fa-heart"></i> Bénévolat & Enseignement</h2>
          <div class="timeline">
            {volunteer.map((v: any) => (
              <div class="tl-item">
                <div class="tl-dot"></div>
                <article class="entry">
                  <div class="entry-header">
                    <div class="entry-title">
                      <strong>{v.position}</strong>
                      <span class="company">@ {v.organization}</span>
                      {v.url && (
                        <a href={v.url} target="_blank" rel="noopener" class="ext" title={v.organization}>
                          <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </a>
                      )}
                    </div>
                    <time>{v.startDate}{v.endDate ? ` → ${v.endDate}` : ''}</time>
                  </div>
                  {v.summary && <p class="muted">{v.summary}</p>}
                  {v.highlights?.length > 0 && (
                    <details class="highlights-toggle" open>
                      <summary><i class="fa-solid fa-chevron-down"></i> {v.highlights.length} point{v.highlights.length > 1 ? 's' : ''} clé{v.highlights.length > 1 ? 's' : ''}</summary>
                      <ul>
                        {v.highlights.map((h: string) => <li>{h}</li>)}
                      </ul>
                    </details>
                  )}
                </article>
              </div>
            ))}
          </div>
        </section>
      )}

      {skills.length > 0 && (
        <section id="competences">
          <h2><i class="fa-solid fa-screwdriver-wrench"></i> Compétences</h2>
          <div class="skills-grid">
            {skills.map((s: any) => (
              <div class="skill-card">
                <div class="skill-meta">
                  <strong>{s.name}</strong>
                  <span class="level-dots">
                    {Array.from({length: 5}, (_, i) => (
                      <span class={`dot ${i < levelDots(s.level) ? 'dot-on' : 'dot-off'}`}></span>
                    ))}
                  </span>
                </div>
                {s.keywords?.length > 0 && (
                  <div class="tags">
                    {s.keywords.map((k: string) => <span class="tag">{k}</span>)}
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {education.length > 0 && (
        <section id="formation">
          <h2><i class="fa-solid fa-graduation-cap"></i> Formation</h2>
          <div class="timeline">
            {education.map((e: any) => (
              <div class="tl-item">
                <div class="tl-dot"></div>
                <article class="entry">
                  <div class="entry-header">
                    <div class="entry-title">
                      <strong>{e.studyType} {e.area}</strong>
                      <span class="company">@ {e.institution}</span>
                    </div>
                    <time>{e.startDate} → {e.endDate ?? 'présent'}</time>
                  </div>
