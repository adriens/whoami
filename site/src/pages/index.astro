            ))}
          </div>
        </section>
      )}

      {openSourceProjects.length > 0 && (
        <section id="open-source">
          <h2><i class="fa-brands fa-github"></i> Projets open source <span class="section-count">{openSourceProjects.length}</span></h2>
          {openSourceProjects.map((p: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{p.name}</strong>
                  {isRecent(p.startDate) && <span class="badge-recent">RÉCENT</span>}
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noopener" class="ext" title={p.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                {p.startDate && (
                  <time>{p.startDate}{p.endDate ? ` → ${p.endDate}` : ''}</time>
                )}
              </div>
              {p.description && <p class="muted">{p.description}</p>}
              {p.highlights?.length > 0 && (
                <ul>
                  {p.highlights.map((h: string) => <li>{h}</li>)}
                </ul>
              )}
            </article>
          ))}
        </section>
      )}

      {professionalProjects.length > 0 && (
        <section id="professionnel">
          <h2><i class="fa-solid fa-building"></i> Réalisations professionnelles <span class="section-count">{professionalProjects.length}</span></h2>
          {professionalProjects.map((p: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{p.name}</strong>
                  {isRecent(p.startDate) && <span class="badge-recent">RÉCENT</span>}
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noopener" class="ext" title={p.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                {p.startDate && (
                  <time>{p.startDate}{p.endDate ? ` → ${p.endDate}` : ''}</time>
                )}
              </div>
              {p.description && <p class="muted">{p.description}</p>}
              {p.highlights?.length > 0 && (
                <ul>
                  {p.highlights.map((h: string) => <li>{h}</li>)}
                </ul>
              )}
            </article>
          ))}
        </section>
      )}

      {publications.length > 0 && (
        <section id="publications">
          <h2><i class="fa-solid fa-file-lines"></i> Publications</h2>
          {publications.map((p: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{p.name}</strong>
                  {p.url && (
                    <a href={p.url} target="_blank" rel="noopener" class="ext" title={p.name}>
                      <i class="fa-solid fa-arrow-up-right-from-square"></i>
                    </a>
                  )}
                </div>
                {p.releaseDate && <time>{p.releaseDate}</time>}
              </div>
              {p.summary && <p class="muted">{p.summary}</p>}
            </article>
          ))}
        </section>
      )}

      {sortedAwards.length > 0 && (
        <section id="distinctions">
          <h2><i class="fa-solid fa-trophy"></i> Distinctions</h2>
          {sortedAwards.map((a: any) => (
            <article class="entry">
              <div class="entry-header">
                <div class="entry-title">
                  <strong>{a.title}</strong>
                  {isRecent(a.date) && <span class="badge-recent">RÉCENT</span>}
                  {a.awarder && <span class="company">@ {a.awarder}</span>}
                </div>
                {a.date && <span class={awardBadgeClass(a.date)}>{a.date.substring(0, 4)}</span>}
              </div>
              {a.summary && <p class="muted">{a.summary}</p>}
            </article>
          ))}
        </section>
      )}

      <!-- ── Derniers articles DEV.to ───────────────────────── -->
      {latestArticles.length > 0 && (
        <section id="articles">
          <h2>
            <i class="fa-brands fa-dev"></i> Derniers articles DEV.to
          </h2>
          <div class="content-grid">
            {latestArticles.map((a) => (
              <a href={a.url} target="_blank" rel="noopener" class="content-card">
                <span class="content-card-title">{a.title}</span>
                <span class="content-card-meta">
                  <span class="article-date">{formatDate(a.published_at)}</span>
                  {a.reactions && parseInt(a.reactions) > 0 && (
                    <span class="article-stat"><i class="fa-solid fa-heart"></i> {a.reactions}</span>
                  )}
                  {a.reading_time_minutes && (
