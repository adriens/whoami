      )}
      <section class="cta-section">
        <p class="cta-title">Envie de collaborer ?</p>
        <p class="cta-sub">Toujours partant pour un projet data, une conférence, un échange open source ou une opportunité depuis la Nouvelle-Calédonie.</p>
        <div class="cta-links">
          {basics.email && (
            <a href={`mailto:${basics.email}`} class="cta-btn" data-copy-email={basics.email}>
              <i class="fa-solid fa-envelope"></i> Email
            </a>
          )}
          {linkedinProfile && (
            <a href={linkedinProfile.url} target="_blank" rel="noopener" class="cta-btn">
              <i class="fa-brands fa-linkedin"></i> LinkedIn
            </a>
          )}
          {githubProfile && (
            <a href={githubProfile.url} target="_blank" rel="noopener" class="cta-btn">
              <i class="fa-brands fa-github"></i> GitHub
            </a>
          )}
        </div>
      </section>
    </main>

    <footer>
      <a href="https://github.com/adriens/whoami" target="_blank" rel="noopener" title="Source — adriens/whoami">
        <i class="fa-brands fa-github"></i>
      </a>
      <a href="https://raw.githubusercontent.com/adriens/whoami/main/manual/resume.json" target="_blank" rel="noopener" title="resume.json">
        <i class="fa-solid fa-file-code"></i>
      </a>
    </footer>
    <script>
      // Scroll progress bar
      const bar = document.getElementById('progress-bar');
      window.addEventListener('scroll', () => {
        const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
        if (bar) bar.style.width = pct + '%';
      });

      // ── D: Theme — respect system preference as default ──
      const root = document.documentElement;
      const btn = document.getElementById('theme-toggle');
      const saved = localStorage.getItem('theme');
      if (saved) {
        root.setAttribute('data-theme', saved);
      } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
        root.setAttribute('data-theme', 'light');
      }

      btn?.addEventListener('click', () => {
        const isLight = root.getAttribute('data-theme') === 'light';
        root.setAttribute('data-theme', isLight ? 'dark' : 'light');
        localStorage.setItem('theme', isLight ? 'dark' : 'light');
      });

      // ── B: PDF export ──
      document.getElementById('pdf-btn')?.addEventListener('click', () => window.print());

      // ── C: Copy email to clipboard ──
      function showToast(msg: string) {
        const t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.classList.add('toast-show');
        setTimeout(() => t.classList.remove('toast-show'), 2000);
      }

      document.querySelector('[data-copy-email]')?.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const email = el.getAttribute('data-copy-email');
        if (!email) return;
        try {
          e.preventDefault();
          await navigator.clipboard.writeText(email);
          showToast('📋 Email copié !');
        } catch { /* fallback: mailto: proceeds */ }
      });

      // ── C: Animated stat counters ──
      const statEls = document.querySelectorAll<HTMLElement>('.stat-value');
      const counterObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const original = el.textContent?.trim() || '';
          const suffix = original.endsWith('+') ? '+' : '';
          const target = parseFloat(original.replace(/\s/g, '').replace(/\+$/, ''));
          if (isNaN(target) || target === 0) return;
          const large = target >= 1000;
          const t0 = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - t0) / 1000, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            const v = Math.round(eased * target);
            el.textContent = (large ? v.toLocaleString('fr') : String(v)) + suffix;
            if (p < 1) requestAnimationFrame(tick); else el.textContent = original;
          };
          requestAnimationFrame(tick);
          counterObs.unobserve(el);
        });
      }, { threshold: 0.5 });
      statEls.forEach(el => counterObs.observe(el));

      // ── A: Side nav active section ──
      const sections = document.querySelectorAll<HTMLElement>('section[id]');
      const navLinks = document.querySelectorAll<HTMLElement>('.snav-link');
      const sectionObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            navLinks.forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
            });
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      sections.forEach(s => sectionObs.observe(s));
    </script>
  </body>
</html>

