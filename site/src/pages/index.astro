                    <span class="article-stat"><i class="fa-solid fa-eye"></i> {parseInt(d.view_count).toLocaleString('fr')}</span>
                  )}
                  {d.last_updated && <span class="article-date">{formatDate(d.last_updated)}</span>}
                </span>
              </a>
